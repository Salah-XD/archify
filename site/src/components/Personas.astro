---
import SectionHeader from './SectionHeader.astro';
const people = [
  { who: 'Frontend engineers', quote: '"I can see where the bug shows up. I can’t see where it starts."', gain: 'Trace a symptom to its component and the API behind it — in seconds.' },
  { who: 'QA engineers', quote: '"My bug reports need more technical context."', gain: 'Attach the component, the request, and the status to every report.' },
  { who: 'Technical founders', quote: '"I can see the product. I can’t see the system."', gain: 'Read a competitor’s stack, hosting, and architecture from the outside.' },
];
---
<section class="mx-auto max-w-5xl px-6 py-20">
  <SectionHeader title="WHO IT'S FOR" />
  <div class="grid gap-4 md:grid-cols-3">
    {people.map((p) => (
      <div class="border border-ink/70 bg-paper p-5">
        <div class="flex items-center gap-2">
          <span class="h-1 w-1 bg-redline"></span>
          <h3 class="text-[13px] font-semibold">{p.who}</h3>
        </div>
        <p class="mt-3 text-[12px] italic leading-relaxed text-ink-2">{p.quote}</p>
        <p class="mt-2 border-t border-line pt-2 text-[11px] leading-relaxed text-muted">{p.gain}</p>
      </div>
    ))}
  </div>
</section>
