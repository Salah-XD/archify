---
import SectionHeader from './SectionHeader.astro';
import { GLASSWATCH_URL } from '../consts';
---
<section id="security" class="mx-auto max-w-5xl px-6 py-20">
  <SectionHeader title="SECURITY" />
  <div class="grid gap-10 md:grid-cols-[1fr_1fr]">
    <div>
      <h2 class="text-2xl font-semibold leading-tight tracking-tight md:text-3xl">
        See what touches your data.
      </h2>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-ink-2">
        Archify surfaces every third-party script, every outbound call, and — most importantly —
        which scripts can read your form and payment fields. The kind of client-side exposure that
        a network firewall never sees.
      </p>
      <a href={GLASSWATCH_URL} target="_blank" rel="noopener noreferrer"
         class="mt-6 inline-flex items-center gap-2 border border-ink/80 px-4 py-2.5 text-[12px] hover:bg-ink hover:text-paper">
        <span>Need it monitored continuously, across every deploy?</span>
        <span class="font-semibold text-redline">Glasswatch →</span>
      </a>
    </div>

    <div class="border border-ink bg-paper">
      <div class="flex items-center gap-2 border-b border-ink/80 px-3 py-2">
        <span class="h-1.5 w-1.5 bg-redline"></span>
        <span class="text-[10px] font-semibold tracking-[0.28em]">ARCHIFY · SECURITY</span>
      </div>
      <div class="space-y-2.5 p-4 text-[12px]">
        <div class="flex justify-between"><span class="text-muted">third-party scripts</span><span class="font-mono">14 / 31</span></div>
        <div class="flex justify-between"><span class="text-muted">outbound domains</span><span class="font-mono">6</span></div>
        <div class="border-t border-line pt-2.5">
          <div class="mb-1 text-[9px] font-semibold tracking-[0.24em] text-muted">FORM / PAYMENT FIELD ACCESS</div>
          <div class="flex items-start gap-1.5 bg-redline/10 px-2 py-1.5 text-[11px]">
            <span class="font-bold text-redline">!</span>
            <span><span class="font-semibold">tag.unknown-cdn.io</span> can read the card-number field</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
