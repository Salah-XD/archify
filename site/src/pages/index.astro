---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Evidence from '../components/Evidence.astro';
import LiveDemo from '../components/LiveDemo.svelte';
import HowItWorks from '../components/HowItWorks.astro';
import Compare from '../components/Compare.astro';
import DetectRegistry from '../components/DetectRegistry.astro';
import Personas from '../components/Personas.astro';
import SecuritySection from '../components/SecuritySection.astro';
import Faq from '../components/Faq.astro';
import GlasswatchCTA from '../components/GlasswatchCTA.astro';
import Footer from '../components/Footer.astro';
import WaitlistModal from '../components/WaitlistModal.svelte';
---
<Base>
  <Navbar />
  <Hero />
  <Problem />
  <Evidence />
  <LiveDemo client:load />
  <HowItWorks />
  <Compare />

  <DetectRegistry />

  <Personas />
  <SecuritySection />
  <Faq />
  <GlasswatchCTA />
  <Footer />
  <WaitlistModal client:load />
</Base>
